build() {
    cd "${pkgname}-${pkgver}"
    cmake -S . -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_CXX_SCAN_FOR_MODULES=OFF
    cmake --build build --parallel
}

package() {
    cd "${pkgname}-${pkgver}"
    DESTDIR="${pkgdir}" cmake --install build --component arsenic
}

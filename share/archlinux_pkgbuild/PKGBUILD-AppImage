#
# Installe le binaire AppImage pré-compilé depuis la dernière release GitHub.
# Toutes les dépendances (Qt, Botan, etc.) sont embarquées dans l'AppImage.
# La variable APPIMAGE_EXTRACT_AND_RUN évite d'avoir besoin de fuse2 au runtime.

pkgname=arsenic-appimage
pkgver=6.0.4
pkgrel=1
pkgdesc="Strong triple encryption tool (AppImage pre-built)"
arch=('x86_64')
url="https://github.com/Antidote1911/arsenic"
license=('GPL3')
provides=('arsenic')
conflicts=('arsenic' 'arsenic-git')
depends=()
options=('!strip')
noextract=("arsenic-${pkgver}-linux-x86_64.AppImage")
source=("arsenic-${pkgver}-linux-x86_64.AppImage::https://github.com/Antidote1911/arsenic/releases/download/v${pkgver}/arsenic-${pkgver}-linux-x86_64.AppImage")
sha256sums=('SKIP')

prepare() {
    chmod +x "arsenic-${pkgver}-linux-x86_64.AppImage"
    # Extraire le squashfs pour récupérer le .desktop et l'icône
    # --appimage-extract ne nécessite pas FUSE
    "./arsenic-${pkgver}-linux-x86_64.AppImage" --appimage-extract > /dev/null
    mv squashfs-root arsenic-squashfs
}

package() {
    # AppImage dans /opt
    install -Dm755 "arsenic-${pkgver}-linux-x86_64.AppImage" \
        "${pkgdir}/opt/arsenic/arsenic.AppImage"

    # Script wrapper : utilise APPIMAGE_EXTRACT_AND_RUN pour éviter fuse2
    install -dm755 "${pkgdir}/usr/bin"
    cat > "${pkgdir}/usr/bin/arsenic" << 'EOF'
#!/bin/sh
exec env APPIMAGE_EXTRACT_AND_RUN=1 /opt/arsenic/arsenic.AppImage "$@"
EOF
    chmod 755 "${pkgdir}/usr/bin/arsenic"

    # Intégration bureau extraite de l'AppImage
    install -Dm644 "arsenic-squashfs/arsenic.desktop" \
        "${pkgdir}/usr/share/applications/arsenic.desktop"
    install -Dm644 "arsenic-squashfs/arsenic.png" \
        "${pkgdir}/usr/share/icons/hicolor/256x256/apps/arsenic.png"
}
